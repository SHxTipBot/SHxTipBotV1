# ──────────────────────────────────────────────────
# SHx Tip Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
ADMIN_DISCORD_IDS=comma,separated,admin,discord,ids

# ── Stellar Network ──────────────────────────────
# "testnet" or "public"
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── SHx Token ────────────────────────────────────
SHX_ASSET_CODE=SHX
SHX_ISSUER=GDSTRSHXHGJ7ZIVRBXEYE5Q74XUVCUSEKEBR7UCHEUUEK72N7I7KJ6JH

# ── Soroban Contracts ────────────────────────────
SOROBAN_CONTRACT_ID=your_deployed_tipping_contract_id
SHX_SAC_CONTRACT_ID=your_shx_stellar_asset_contract_id

# ── Bot House Account (pays XLM network fees) ───
HOUSE_ACCOUNT_SECRET=your_house_account_secret_key
HOUSE_ACCOUNT_PUBLIC=your_house_account_public_key

# ── Treasury Account (receives SHx fees) ────────
TREASURY_ACCOUNT=your_treasury_stellar_public_key

# ── Fee Configuration ────────────────────────────
# Minimum fee floor in SHx (used when DEX price unavailable)
MIN_FEE_SHX=0.1
# Buffer percentage added to calculated fee for volatility
FEE_BUFFER_PERCENT=10
# Fallback fee if DEX price lookup fails entirely
FALLBACK_FEE_SHX=5.0
# Estimated XLM cost of a Soroban invocation (conservative)
ESTIMATED_XLM_FEE=0.05

# ── Rate Limiting ────────────────────────────────
RATE_LIMIT_TIPS_PER_MINUTE=5

# ── Web Application ─────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_BASE_URL=http://localhost:8080

# ── Logging ──────────────────────────────────────
LOG_FILE=shx_tip_bot.log
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────
DB_PATH=shx_tip_bot.db
WC_PROJECT_ID=??_PROJECT_ID
