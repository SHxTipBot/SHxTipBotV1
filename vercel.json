{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Content-Security-Policy", "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; script-src * 'unsafe-inline' 'unsafe-eval' blob:; connect-src * wss: ws:; style-src * 'unsafe-inline'; img-src * data: blob:; font-src * data:; frame-src *;" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/public/(.*)",
      "destination": "/src_public/$1"
    },
    {
      "source": "/",
      "destination": "/api/index.py"
    },
    {
      "source": "/link",
      "destination": "/api/index.py"
    },
    {
      "source": "/register",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
