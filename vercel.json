{
    "version": 2,
    "rewrites": [
        {
            "source": "/",
            "destination": "/api/index.py"
        },
        {
            "source": "/register",
            "destination": "/api/index.py"
        },
        {
            "source": "/health",
            "destination": "/api/index.py"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/static/(.*)",
            "destination": "/web_static/$1"
        }
    ]
}