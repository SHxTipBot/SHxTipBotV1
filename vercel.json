{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "web_static/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/register",
            "dest": "api/index.py"
        },
        {
            "src": "/api/(.*)",
            "dest": "api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "web_static/$1"
        }
    ]
}